{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "lib": ["ES2022"],

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,

    "isolatedModules": true,
    
    "jsx": "react-jsx",

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"]
    }
  },

  "include": ["src/**/*"],

  "exclude": [
    "node_modules",
    "dist"
  ]
}