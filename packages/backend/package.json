{
  "name": "@sweet-affinity/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",

  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },

  "scripts": {
    "clean": "node -e \"import('node:fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\"",

    "dev": "tsx watch src/index.ts",

    "dev:debug": "cross-env NODE_ENV=development tsx watch src/index.ts",

    "build": "npm run clean && tsc",

    "start": "cross-env NODE_ENV=production node dist/index.js",

    "typecheck": "tsc --noEmit",

    "db:generate": "drizzle-kit generate",

    "db:migrate": "drizzle-kit migrate",

    "db:studio": "drizzle-kit studio"
  },

  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",

    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/oauth2": "^7.1.1",
    "@fastify/rate-limit": "^9.1.0",

    "bcryptjs": "^3.0.2",

    "dotenv": "^16.4.5",

    "drizzle-orm": "^0.45.2",

    "fastify": "^4.26.1",

    "ioredis": "^5.4.1",

    "pg": "^8.22.0",

    "socket.io": "^4.7.4"
  },

  "devDependencies": {
    "@types/node": "^24.0.0",

    "@types/pg": "^8.11.4",

    "cross-env": "^10.0.0",

    "drizzle-kit": "^0.30.0",

    "pino-pretty": "^11.0.0",

    "tsx": "^4.20.3",

    "typescript": "^5.9.2"
  }
}