# ─────────────────────────────────────────────
# APLICAÇÃO
# ─────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
PORT=4000

JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d

# ─────────────────────────────────────────────
# ─────────────────────────────────────────────
# BANCO DE DADOS (Ex: Neon.tech PostgreSQL)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://neondb_owner:npg_9IyBOpftWAU5@ep-floral-feather-ac7hgpbz-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DATABASE_MAX_CONNECTIONS=20

# ─────────────────────────────────────────────
# REDIS (Ex: Upstash Serverless Redis)
# ─────────────────────────────────────────────
REDIS_URL=rediss://default:password@upstash_url:6379
UPSTASH_REDIS_REST_URL="https://your-upstash-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token"

# ─────────────────────────────────────────────
# STORAGE (S3 Compatível / Cloudflare R2)
# ─────────────────────────────────────────────
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_ENDPOINT_URL_S3=https://your-account-id.r2.cloudflarestorage.com
S3_BUCKET_NAME=sweetaffinity-assets
S3_PUBLIC_URL=https://pub-xxxx.r2.dev

# ─────────────────────────────────────────────
# GOOGLE OAUTH
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/callback

# ─────────────────────────────────────────────
# RECAPTCHA
# ─────────────────────────────────────────────
RECAPTCHA_SITE_KEY=your_site_key
RECAPTCHA_SECRET_KEY=your_secret_key

# ─────────────────────────────────────────────
# EMAIL (RESEND)
# ─────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@example.com
EMAIL_REPLY_TO=support@example.com

# ─────────────────────────────────────────────
# STRIPE
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret
STRIPE_PUBLISHABLE_KEY=your_stripe_public_key
STRIPE_WEBHOOK_SECRET=your_webhook_secret
STRIPE_WEBHOOK_URL=http://localhost:4000/payments/webhook/stripe

# ─────────────────────────────────────────────
# MONITORAMENTO
# ─────────────────────────────────────────────
SENTRY_DSN=your_sentry_dsn
LOG_LEVEL=info