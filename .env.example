# ─────────────────────────────────────────────
# APLICAÇÃO
# ─────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
PORT=4000

JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d

# ─────────────────────────────────────────────
# BANCO DE DADOS
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/database
DATABASE_MAX_CONNECTIONS=20

# ─────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# STORAGE (MINIO / S3)
# ─────────────────────────────────────────────
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key
MINIO_BUCKET_NAME=your_bucket_name
MINIO_PUBLIC_URL=http://localhost:9000/your_bucket_name

# ─────────────────────────────────────────────
# GOOGLE OAUTH
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/callback

# ─────────────────────────────────────────────
# RECAPTCHA
# ─────────────────────────────────────────────
RECAPTCHA_SITE_KEY=your_site_key
RECAPTCHA_SECRET_KEY=your_secret_key

# ─────────────────────────────────────────────
# EMAIL (RESEND)
# ─────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@example.com
EMAIL_REPLY_TO=support@example.com

# ─────────────────────────────────────────────
# STRIPE
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret
STRIPE_PUBLISHABLE_KEY=your_stripe_public_key
STRIPE_WEBHOOK_SECRET=your_webhook_secret
STRIPE_WEBHOOK_URL=http://localhost:4000/payments/webhook/stripe

# ─────────────────────────────────────────────
# MONITORAMENTO
# ─────────────────────────────────────────────
SENTRY_DSN=your_sentry_dsn
LOG_LEVEL=info