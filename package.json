{
  "name": "sweet-affinity",
  "version": "1.0.0",
  "private": true,

  "workspaces": [
    "packages/*"
  ],

  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },

  "scripts": {
    "dev": "npm run dev --workspaces",

    "dev:frontend": "npm run dev -w packages/frontend",
    "dev:backend": "npm run dev -w packages/backend",

    "build": "npm run build --workspaces",

    "build:frontend": "npm run build -w packages/frontend",
    "build:backend": "npm run build -w packages/backend",

    "start:backend": "npm run start -w packages/backend",

    "typecheck": "npm run typecheck --workspaces",

    "clean": "npm run clean --if-present --workspaces",

    "db:generate": "npm run db:generate -w packages/backend",
    "db:push": "npm run db:push -w packages/backend",
    "db:migrate": "npm run db:migrate -w packages/backend"
  },

  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.2"
  }
}